<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.MainController">
    <left>
        <VBox spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 20;" prefWidth="200.0">
            <children>
                <Label text="EASY TRANS" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18;" />
                <Separator />
                <Button text="Dashboard" onAction="#showDashboard" maxWidth="Infinity" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" />
                <Button text="Véhicules" onAction="#showVehicules" maxWidth="Infinity" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" />
                <Button text="Paramètres" onAction="#showParametres" maxWidth="Infinity" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" />
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" />
    </center>
</BorderPane>